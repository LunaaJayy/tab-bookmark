{
	"manifest_version": 3,

	"name": "Tab Bookmark",

	"version": "1.0",

	"description": "A Tab Bookmark for screenreaders, it starts reading where you bookmarked",

	"icons": {
		"16": "images/icon-16.png",
		"32": "images/icon-32.png",
		"48": "images/icon-48.png",
		"128": "images/icon-128.png"
	},

	"permissions": ["activeTab", "storage", "commands"],

	"action": {
    	"default_popup": "tabmark.html",
    	"default_icon": "images/icon.png"
  	},

	"background": {
		"service_worker": "background.js"
	},

	"commands": {
		"add-bookmark": {
			"suggested_key": {
				"default": "Ctrl+Shift+Y"
			},
			"description": "Adds current tab to bookmark"
		}
	}
}